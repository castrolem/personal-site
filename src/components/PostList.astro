---
import { render } from "astro:content";
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import { Button } from "@/components/ui/button";
import type { PostEntry } from "@/lib/posts";

interface Props {
  posts: PostEntry[];
  emptyTitle: string;
  emptyMessage: string;
}

const { posts, emptyTitle, emptyMessage } = Astro.props as Props;

const formatDate = (value: Date) =>
  value.toLocaleDateString("en", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });

const markdown = await createMarkdownProcessor();

const renderedPosts = await Promise.all(
  posts.map(async (post) => {
    if (post.data.preview) {
      const fileURL = post.filePath
        ? new URL(`../../${post.filePath}`, import.meta.url)
        : undefined;
      const result = await markdown.render(post.data.preview, {
        fileURL,
        frontmatter: post.data,
      });

      return {
        post,
        previewHtml: result.code,
      };
    }

    const { Content } = await render(post);

    return {
      post,
      Content,
    };
  }),
);
---

{
  renderedPosts.length > 0 ? (
    <ul class="space-y-24">
      {renderedPosts.map(({ post, previewHtml, Content }) => (
        <li>
          <article class="py-4">
            <div class="flex items-baseline justify-between gap-4">
              <h2 class="text-xl leading-tight">
                <a
                  class="transition-colors hover:text-muted-foreground"
                  href={`/posts/${post.id}/`}
                >
                  {post.data.title}
                </a>
              </h2>
              <p class="shrink-0 text-sm text-muted-foreground">
                {formatDate(post.data.publishedAt)}
              </p>
            </div>

            <div class="mt-4 space-y-4 text-base leading-8 text-foreground [&_a]:underline [&_img]:rounded-2xl [&_img]:border [&_img]:border-border [&_img]:shadow-sm [&_p]:text-foreground [&_ul]:list-disc [&_ul]:pl-5 [&_ol]:list-decimal [&_ol]:pl-5">
              {previewHtml ? (
                <Fragment set:html={previewHtml} />
              ) : (
                Content && <Content />
              )}
            </div>

            {post.data.tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="rounded-full bg-muted px-2.5 py-1 text-xs text-muted-foreground">
                    {tag}
                  </span>
                ))}
              </div>
            )}

            <div class="mt-4">
              <Button href={`/posts/${post.id}/`} size="sm" variant="secondary">
                Open post
              </Button>
            </div>
          </article>
        </li>
      ))}
    </ul>
  ) : (
    <div class="rounded-3xl border border-dashed border-border bg-card px-5 py-6">
      <h2 class="text-lg">{emptyTitle}</h2>
      <p class="mt-2 text-sm leading-6 text-muted-foreground">{emptyMessage}</p>
    </div>
  )
}
