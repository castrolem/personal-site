---
import { render } from "astro:content";
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import { Button } from "@/components/ui/button";
import { PostAuthor } from "@/components/PostAuthor";
import type { PostEntry } from "@/lib/posts";
import { getPostsByTag, getPublishedPosts } from "@/lib/posts";

interface Props {
  posts: PostEntry[];
  emptyTitle: string;
  emptyMessage: string;
}

const { posts, emptyTitle, emptyMessage } = Astro.props as Props;

const formatDate = (value: Date) =>
  value.toLocaleDateString("en", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });

const markdown = await createMarkdownProcessor();
const [allPosts, bookPosts] = await Promise.all([
  getPublishedPosts(),
  getPostsByTag("#book"),
]);

const renderedPosts = await Promise.all(
  posts.map(async (post) => {
    if (post.data.preview) {
      const fileURL = post.filePath
        ? new URL(`../../${post.filePath}`, import.meta.url)
        : undefined;
      const result = await markdown.render(post.data.preview, {
        fileURL,
        frontmatter: post.data,
      });

      return {
        post,
        previewHtml: result.code,
      };
    }

    const { Content } = await render(post);

    return {
      post,
      Content,
    };
  }),
);
---

{
  renderedPosts.length > 0 ? (
    <ul class="space-y-24">
      {renderedPosts.map(({ post, previewHtml, Content }) => (
        <li>
          <article class="space-y-6 py-2">
            <PostAuthor
              client:idle
              transition:persist
              publishedAt={formatDate(post.data.publishedAt)}
              totalBooks={bookPosts.length}
              totalPosts={allPosts.length}
            />

            <div class="pl-16">
              <div class="space-y-4 text-foreground [&_a]:text-primary [&_a]:no-underline hover:[&_a]:underline [&_img]:rounded-3xl [&_img]:border [&_img]:border-border [&_img]:shadow-sm [&_p]:text-foreground [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:list-decimal [&_ol]:pl-6">
                {previewHtml ? (
                  <Fragment set:html={previewHtml} />
                ) : (
                  Content && <Content />
                )}
              </div>

              <div class="mt-5">
                <Button
                  href={`/posts/${post.id}/`}
                  size="sm"
                  variant="secondary"
                >
                  Open post
                </Button>
              </div>
            </div>
          </article>
        </li>
      ))}
    </ul>
  ) : (
    <div class="rounded-3xl border border-dashed border-border bg-card px-5 py-6">
      <h2 class="text-lg">{emptyTitle}</h2>
      <p class="mt-2 text-sm leading-6 text-muted-foreground">{emptyMessage}</p>
    </div>
  )
}
