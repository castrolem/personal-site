---
import PostList from "@/components/PostList.astro";
import { Button } from "@/components/ui/button";
import type { PostEntry } from "@/lib/posts";

interface Props {
  posts: PostEntry[];
  currentPage: number;
  totalPages: number;
  totalPosts: number;
  basePath?: string;
}

const { posts, currentPage, totalPages, basePath = "/" } = Astro.props as Props;

const buildPageHref = (page: number) => {
  if (page <= 1) {
    return basePath;
  }

  return basePath === "/" ? `/page/${page}/` : `${basePath}/page/${page}/`;
};

const pageLinks = Array.from({ length: totalPages }, (_, index) => index + 1);
---

<section class="space-y-8">
  <PostList
    posts={posts}
    emptyTitle="No posts yet"
    emptyMessage="Add markdown files under `src/content/posts` and they will show up here automatically."
  />

  {
    totalPages > 1 && (
      <nav
        aria-label="Pagination"
        class="flex flex-wrap items-center justify-center gap-2 py-10"
      >
        {pageLinks.map((page) => (
          <Button
            href={buildPageHref(page)}
            variant={page === currentPage ? "default" : "outline"}
            size="icon"
          >
            {page}
          </Button>
        ))}
      </nav>
    )
  }
</section>
