---
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Luis Castro",
  description = "Writing, notes, and references.",
} = Astro.props as Props;

const navigation = [
  { href: "/", label: "Posts" },
  { href: "/dailies", label: "Dailies" },
  { href: "/library", label: "Library" },
  { href: "/about", label: "About" },
];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-svh bg-background text-foreground">
    <div
      class="mx-auto flex min-h-svh w-full max-w-2xl flex-col px-6 py-10 sm:px-8 sm:py-12"
    >
      <header class="sticky top-6 z-20 mb-12 flex justify-center">
        <nav
          aria-label="Primary"
          class="flex w-fit max-w-full flex-wrap items-center justify-center gap-2 rounded-[2rem] border border-border/70 bg-card/80 p-1 backdrop-blur-md"
        >
          {
            navigation.map(({ href, label }) => {
              const isActive =
                href === "/"
                  ? pathname === "/" ||
                    pathname === "/posts" ||
                    pathname.startsWith("/page/")
                  : pathname === href || pathname.startsWith(`${href}/`);

              return (
                <a
                  class:list={[
                    "rounded-full border px-5 py-2.5 text-sm font-medium transition-colors",
                    isActive
                      ? "border-background bg-background text-foreground"
                      : "border-transparent bg-transparent text-muted-foreground hover:text-foreground",
                  ]}
                  href={href}
                >
                  {label}
                </a>
              );
            })
          }
        </nav>
      </header>

      <main class="flex-1">
        <slot />
      </main>

      <footer
        class="mt-16 border-t border-border pt-6 text-sm text-muted-foreground"
      >
        Built with Astro.
      </footer>
    </div>
  </body>
</html>
