---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import { HugeiconsIcon } from "@hugeicons/react";
import {
  BookOpen01Icon,
  Calendar03Icon,
  News01Icon,
  UserIcon,
} from "@hugeicons/core-free-icons";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Luis Castro",
  description = "Writing, notes, and references.",
} = Astro.props as Props;

const navigation = [
  { href: "/", label: "Posts", icon: News01Icon },
  { href: "/dailies", label: "Dailies", icon: Calendar03Icon },
  { href: "/library", label: "Library", icon: BookOpen01Icon },
  { href: "/about", label: "About", icon: UserIcon },
];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="min-h-svh bg-background text-foreground">
    <div
      class="mx-auto flex min-h-svh w-full max-w-2xl flex-col px-6 py-10 sm:px-8 sm:py-12"
    >
      <header class="sticky top-6 z-20 mb-12 flex justify-center">
        <nav
          aria-label="Primary"
          class="flex w-fit max-w-full flex-wrap items-center justify-center gap-2 rounded-full border border-border/20 p-1 backdrop-blur-lg"
        >
          {
            navigation.map(({ href, label, icon }) => {
              const isActive =
                href === "/"
                  ? pathname === "/" ||
                    pathname === "/posts" ||
                    pathname.startsWith("/page/")
                  : pathname === href || pathname.startsWith(`${href}/`);

              return (
                <a
                  class:list={[
                    "inline-flex items-center gap-2 rounded-full border px-5 py-2.5 text-sm font-medium transition-colors",
                    isActive
                      ? "border-background bg-background text-foreground"
                      : "border-transparent bg-transparent text-muted-foreground hover:text-foreground",
                  ]}
                  href={href}
                >
                  <HugeiconsIcon
                    aria-hidden="true"
                    className="size-4 shrink-0"
                    color="currentColor"
                    icon={icon}
                    size={16}
                    strokeWidth={1.8}
                  />
                  {label}
                </a>
              );
            })
          }
        </nav>
      </header>

      <main class="flex-1">
        <slot />
      </main>

      <footer
        class="mt-16 border-t border-border pt-6 text-sm text-muted-foreground"
      >
        Built with Astro.
      </footer>
    </div>
  </body>
</html>
