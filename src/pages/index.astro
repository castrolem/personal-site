---
import Layout from "@/layouts/main.astro"
---

<Layout>
  <main class="mx-auto flex min-h-svh w-full max-w-6xl flex-col gap-10 px-6 py-8 sm:px-10 lg:px-12">
    <header class="flex flex-col gap-6 rounded-4xl border bg-card/80 p-6 shadow-sm backdrop-blur sm:p-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="max-w-2xl space-y-4">
          <p class="text-sm uppercase tracking-[0.24em] text-muted-foreground">
            Braun-inspired palette
          </p>
          <div class="space-y-3">
            <h1 class="max-w-xl text-4xl leading-none font-medium text-balance sm:text-5xl">
              Warm neutrals, signal orange, and sage green translated into semantic tokens.
            </h1>
            <p class="max-w-xl text-base leading-7 text-muted-foreground sm:text-lg">
              The theme pulls from the white casings, soft grey wall, black linework, orange dial,
              and sage control in the reference image. Token pairings were selected to keep normal
              text at or above WCAG AA contrast in both themes.
            </p>
          </div>
        </div>

        <div class="rounded-full border bg-background/75 px-4 py-2 text-sm text-muted-foreground">
          Follows system appearance via CSS media queries
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-4">
        <div class="rounded-3xl border bg-background p-4">
          <p class="text-sm text-muted-foreground">Background</p>
          <p class="mt-2 text-2xl">Soft paper</p>
          <p class="mt-3 font-mono text-xs text-muted-foreground">`background` / `card`</p>
        </div>
        <div class="rounded-3xl border bg-primary p-4 text-primary-foreground">
          <p class="text-sm/none opacity-80">Primary</p>
          <p class="mt-2 text-2xl">Ink contrast</p>
          <p class="mt-3 font-mono text-xs opacity-80">`primary`</p>
        </div>
        <div class="rounded-3xl border bg-brand-orange p-4 text-[#181718]">
          <p class="text-sm/none opacity-70">Accent signal</p>
          <p class="mt-2 text-2xl">Orange dial</p>
          <p class="mt-3 font-mono text-xs opacity-70">`brand-orange`</p>
        </div>
        <div class="rounded-3xl border bg-brand-sage p-4 text-[#181718]">
          <p class="text-sm/none opacity-80">Accent support</p>
          <p class="mt-2 text-2xl">Sage switch</p>
          <p class="mt-3 font-mono text-xs opacity-80">`brand-sage`</p>
        </div>
      </div>
    </header>

    <section class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <article class="rounded-4xl border bg-card/85 p-6 shadow-sm backdrop-blur sm:p-8">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground">Token system</p>
            <h2 class="mt-2 text-2xl font-medium">Light and dark roles</h2>
          </div>
          <div class="hidden rounded-full border bg-muted px-3 py-1 text-xs text-muted-foreground sm:block">
            Tailwind v4 semantic tokens
          </div>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="rounded-3xl border bg-background p-5">
            <p class="text-sm text-muted-foreground">Readable surfaces</p>
            <p class="mt-2 text-lg">
              Neutral layers stay slightly warm, matching the product shells instead of drifting
              into sterile blue-grey.
            </p>
          </div>
          <div class="rounded-3xl border bg-muted p-5">
            <p class="text-sm text-muted-foreground">Support hierarchy</p>
            <p class="mt-2 text-lg">
              Muted and secondary tones compress contrast without dropping body text below AA.
            </p>
          </div>
          <div class="rounded-3xl border bg-accent p-5 text-accent-foreground">
            <p class="text-sm opacity-80">Sage accent</p>
            <p class="mt-2 text-lg">
              Used for supportive emphasis, filters, and calm surfaces rather than primary actions.
            </p>
          </div>
          <div class="rounded-3xl border p-5">
            <p class="text-sm text-muted-foreground">High-signal color</p>
            <p class="mt-2 text-lg">
              Orange is reserved for highlights, charts, and focus states so it keeps the same
              visual punch as the original dial.
            </p>
          </div>
        </div>

        <div class="mt-6 flex flex-wrap gap-3 text-sm text-muted-foreground">
          <span class="rounded-full border bg-primary px-4 py-2 text-primary-foreground">
            Primary action
          </span>
          <span class="rounded-full border bg-secondary px-4 py-2 text-secondary-foreground">
            Secondary
          </span>
          <span class="rounded-full border bg-background px-4 py-2 text-foreground">
            Outline
          </span>
          <span class="rounded-full border bg-muted px-4 py-2 text-foreground">Ghost</span>
        </div>
      </article>

      <aside class="rounded-4xl border bg-card/85 p-6 shadow-sm backdrop-blur sm:p-8">
        <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground">Contrast checks</p>
        <h2 class="mt-2 text-2xl font-medium">AA-safe pairings</h2>

        <div class="mt-6 space-y-3">
          <div class="rounded-3xl border bg-background p-4">
            <div class="flex items-center justify-between gap-4">
              <span>Light foreground on paper</span>
              <span class="rounded-full bg-secondary px-2.5 py-1 text-xs">16.1:1</span>
            </div>
          </div>
          <div class="rounded-3xl border bg-primary p-4 text-primary-foreground">
            <div class="flex items-center justify-between gap-4">
              <span>Primary button</span>
              <span class="rounded-full bg-primary-foreground/15 px-2.5 py-1 text-xs">12.7:1</span>
            </div>
          </div>
          <div class="rounded-3xl border bg-accent p-4 text-accent-foreground">
            <div class="flex items-center justify-between gap-4">
              <span>Accent surface</span>
              <span class="rounded-full bg-black/10 px-2.5 py-1 text-xs dark:bg-white/10">
                4.5:1+
              </span>
            </div>
          </div>
          <div class="rounded-3xl border p-4">
            <p class="text-sm leading-6 text-muted-foreground">
              The palette keeps orange and sage expressive, but text-critical roles stay on
              neutral or proven AA-safe surfaces. That avoids the common problem of attractive
              accent colors failing in links, body copy, and low-emphasis UI.
            </p>
          </div>
        </div>
      </aside>
    </section>
  </main>
</Layout>
