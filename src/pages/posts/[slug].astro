---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/main.astro";

export async function getStaticPaths() {
  let posts: CollectionEntry<"posts">[] = [];

  try {
    posts = await getCollection("posts", ({ data }) => !data.draft);
  } catch (error) {
    if (
      !(error instanceof Error) ||
      !error.message.includes('collection "posts" does not exist or is empty')
    ) {
      throw error;
    }
  }

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"posts"> };
const { Content } = await render(post);

const formatDate = (value: Date) =>
  value.toLocaleDateString("en", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<Layout
  title={`${post.data.title} | Luis Castro`}
  description={post.data.description}
>
  <article class="space-y-8">
    <header class="space-y-4">
      <div class="gap-4 flex flex-row items-center justify-between w-full">
        <a
          class="text-sm text-muted-foreground transition-colors hover:text-foreground"
          href="/"
        >
          Back to posts
        </a>

        <p class="text-xs text-muted-foreground ml-auto">
          {formatDate(post.data.publishedAt)}
        </p>
      </div>

      <h1 class="text-2xl font-semibold">{post.data.title}</h1>
    </header>

    <div
      class="space-y-5 text-base leading-8 [&_a]:underline [&_img]:rounded-2xl [&_img]:border [&_img]:border-border [&_img]:shadow-sm [&_ul]:list-disc [&_ul]:pl-5 [&_ol]:list-decimal [&_ol]:pl-5"
    >
      <Content />
    </div>
  </article>
</Layout>
